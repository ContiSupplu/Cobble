# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=your_database_url_here

# Pterodactyl
PTERO_API_URL=your_pterodactyl_url_here
PTERO_API_KEY=your_api_key_here
PTERODACTYL_CLIENT_KEY=your_client_key_here

# Stripe
STRIPE_SECRET_KEY=your_stripe_key_here
STRIPE_WEBHOOK_SECRET=your_webhook_secret_here
STRIPE_PRICE_FREE=your_price_id_here
STRIPE_PRICE_PRO=your_price_id_here
STRIPE_PRICE_PROPLUS=your_price_id_here
STRIPE_PRICE_PROMAX=your_price_id_here

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY=7d

# Domains
DOMAIN=your_domain_here
